# === Rust ===
# Catch every Cargo build directory anywhere in the workspace. The previous
# rule only matched the legacy `/fovia-client/src-tauri/target/` path which
# meant the actual `faceflow-client/src-tauri/target/` (≈12 GB) was *not*
# ignored. Use a glob so any future crate is covered automatically.
**/target/
**/Cargo.lock.bak
**/*.rs.bk

# === Node.js ===
**/node_modules/
**/dist/
**/.vite/
**/*.tsbuildinfo
.parcel-cache/

# === Python ===
**/__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
*.egg
**/.venv/
**/venv/
**/env/
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/

# === Activation (local secrets — never commit) ===
activation.secret
activation_keys.txt
*.secret

# === Models / large binaries downloaded at runtime ===
# InsightFace `buffalo_l` and exiftool live under the user's app-data dir at
# runtime, but during development they may be symlinked or copied here.
faceflow-client/src-tauri/models/
faceflow-client/src-tauri/exiftool/
**/buffalo_l/
**/*.onnx
**/*.zip

# === IDE ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# === Environment ===
.env
.env.local
.env.*.local

# === Build artifacts ===
*.dmg
*.app
*.deb
*.rpm
*.AppImage
*.msi
*.pkg

# === Logs ===
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# === OS ===
.DS_Store
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
._*

# === Misc dev artifacts ===
repomix-output.xml
coverage/
**/*.tmp
**/*.bak

# === Tauri-specific ===
faceflow-client/src-tauri/gen/schemas/
faceflow-client/src-tauri/WixTools/

# === Supabase CLI temp ===
supabase/.temp/
