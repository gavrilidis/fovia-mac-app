{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "FaceFlow",
  "version": "0.1.0",
  "identifier": "com.faceflow.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "FaceFlow",
        "width": 900,
        "height": 650,
        "minWidth": 800,
        "minHeight": 550,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUwNjA0N0ZCMzIzRDgzODIKUldTQ2d6MHkrMGRnNElSRERoNUlhTXlrYmVFVnVYdzhUSUcrT3pNSk5XMUJHQ2FRK3IvQXd6YW4K",
      "endpoints": [
        "https://github.com/gavrilidis/faceflow/releases/latest/download/latest.json"
      ]
    }
  }
}
