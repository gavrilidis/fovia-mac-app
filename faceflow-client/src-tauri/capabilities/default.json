{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "faceflow-*"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "fs:default",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$HOME/Pictures/**"
        },
        {
          "path": "$HOME/Desktop/**"
        },
        {
          "path": "$HOME/Documents/**"
        },
        {
          "path": "$HOME/Downloads/**"
        }
      ]
    },
    "fs:allow-exists",
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$HOME/Pictures/**"
        },
        {
          "path": "$HOME/Desktop/**"
        },
        {
          "path": "$HOME/Documents/**"
        },
        {
          "path": "$HOME/Downloads/**"
        }
      ]
    },
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "exiftool",
          "cmd": "exiftool"
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "exiftool",
          "cmd": "exiftool"
        }
      ]
    },
    "dialog:default",
    "dialog:allow-open",
    "updater:default",
    "process:default"
  ]
}
